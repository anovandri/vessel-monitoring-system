{
  "name": "data-persistence-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/data-persistence-service/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn clean package -DskipTests",
        "cwd": "{workspaceRoot}/apps/data-persistence-service"
      },
      "outputs": ["{workspaceRoot}/apps/data-persistence-service/target"],
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test",
        "cwd": "{workspaceRoot}/apps/data-persistence-service"
      },
      "cache": false
    },
    "integration-test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn verify",
        "cwd": "{workspaceRoot}/apps/data-persistence-service"
      },
      "cache": false
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn spring-boot:run",
        "cwd": "{workspaceRoot}/apps/data-persistence-service"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn clean",
        "cwd": "{workspaceRoot}/apps/data-persistence-service"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn checkstyle:check",
        "cwd": "{workspaceRoot}/apps/data-persistence-service"
      }
    },
    "coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test jacoco:report",
        "cwd": "{workspaceRoot}/apps/data-persistence-service"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn spring-boot:build-image -Dspring-boot.build-image.imageName=vms/data-persistence-service:latest",
        "cwd": "{workspaceRoot}/apps/data-persistence-service"
      }
    }
  },
  "tags": ["type:service", "scope:backend", "platform:spring-boot"]
}
