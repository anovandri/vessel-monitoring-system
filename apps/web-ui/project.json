{
  "name": "web-ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/web-ui",
  "projectType": "application",
  "tags": ["type:application", "platform:nextjs", "scope:frontend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run build",
        "cwd": "{workspaceRoot}/apps/web-ui"
      },
      "outputs": ["{workspaceRoot}/apps/web-ui/.next"],
      "cache": true
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run dev",
        "cwd": "{workspaceRoot}/apps/web-ui"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run start",
        "cwd": "{workspaceRoot}/apps/web-ui"
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint",
        "cwd": "{workspaceRoot}/apps/web-ui"
      },
      "cache": true
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit",
        "cwd": "{workspaceRoot}/apps/web-ui"
      },
      "cache": true
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rm -rf .next node_modules/.cache",
        "cwd": "{workspaceRoot}/apps/web-ui"
      }
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm install",
        "cwd": "{workspaceRoot}/apps/web-ui"
      }
    }
  }
}
