# Flink Stream Processor Configuration

# Flink Stream Processor Environment Configuration
# 
# This file is automatically loaded when running the application locally.
# Copy this file to .env and adjust the values as needed.
# 
# Usage:
#   1. Copy to .env: cp .env.example .env
#   2. Edit values in .env
#   3. Run: mvn exec:java or nx run stream-processor:run
#
# The application will automatically load these variables via dotenv-java library.
#
# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INPUT_TOPIC=ais-raw-data
KAFKA_POSITIONS_TOPIC=vessel-positions
KAFKA_ALERTS_TOPIC=vessel-alerts

# Flink Configuration
FLINK_PARALLELISM=4
FLINK_CHECKPOINTING_ENABLED=true
FLINK_CHECKPOINT_INTERVAL=60000
FLINK_STATE_BACKEND=hashmap
FLINK_CHECKPOINT_DIR=file:///tmp/flink-checkpoints
